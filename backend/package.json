{
  "name": "tutu-admin-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start:dev": "ts-node-dev --respawn --transpile-only --project tsconfig.json src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "db:up": "docker compose -f docker-compose.yml up -d postgres",
    "db:down": "docker compose -f docker-compose.yml down",
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:setup": "npm run prisma:generate && npm run db:push && npm run db:seed"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/platform-express": "^11.1.6",
    "@prisma/client": "^6.7.0",
    "dotenv": "^17.2.3",
    "jsonwebtoken": "^9.0.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.6.0",
    "prisma": "^6.7.0",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
